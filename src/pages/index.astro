---
import "../styles/global.css";
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <!-- Set the .js flag before paint so reveal targets don't flash, and stay visible if JS fails -->
  <script>document.documentElement.classList.add("js");</script>

  <title>Managed IT Services in Cooper City | CYBERCON</title>
  <meta name="description" content="Proactive managed IT services, cybersecurity, cloud, and help desk support for growing South Florida businesses. Get a free CYBERCON assessment." />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <meta name="theme-color" content="#ffffff" />
  <link rel="canonical" href="https://www.cyberconsolutions.com/" />

  <!-- Local SEO -->
  <meta name="geo.region" content="US-FL" />
  <meta name="geo.placename" content="Cooper City, Florida" />

  <!-- Open Graph / Twitter -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="CYBERCON Solutions" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:title" content="Managed IT Services in Cooper City | CYBERCON" />
  <meta property="og:description" content="Proactive, security-first managed IT for growing South Florida businesses — explained clearly and owned fully." />
  <meta property="og:url" content="https://www.cyberconsolutions.com/" />
  <meta property="og:image" content="https://www.cyberconsolutions.com/assets/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://www.cyberconsolutions.com/assets/og-image.png" />
  <meta name="twitter:title" content="Managed IT Services in Cooper City | CYBERCON" />
  <meta name="twitter:description" content="Proactive, security-first managed IT for growing South Florida businesses — explained clearly and owned fully." />

  <link rel="icon" href="favicon.ico" sizes="any" />
  <link rel="icon" type="image/svg+xml" href="favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="favicon-16x16.png" />
  <link rel="apple-touch-icon" href="apple-touch-icon.png" />
  <link rel="manifest" href="site.webmanifest" />

  <!-- Deferred: run in order after parse, before DOMContentLoaded -->
  <script src="assets/vendor/lucide.min.js" defer></script>
  <script src="app.js?v=8" defer></script>

  <!-- Local business structured data. Add verified phone/street details when available. -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "@id": "https://www.cyberconsolutions.com/#business",
    "name": "Cybercon Solutions",
    "description": "Managed IT, cybersecurity, cloud, and AI automation for small and mid-sized businesses in Cooper City and South Florida.",
    "url": "https://www.cyberconsolutions.com/",
    "image": "https://www.cyberconsolutions.com/assets/brand/logo-cybercon-solutions.svg",
    "priceRange": "$$",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Cooper City",
      "addressRegion": "FL",
      "postalCode": "33330",
      "addressCountry": "US"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": 26.0573, "longitude": -80.2717 },
    "areaServed": [
      "Cooper City", "Davie", "Pembroke Pines", "Weston",
      "Plantation", "Hollywood", "Miramar", "Fort Lauderdale"
    ],
    "openingHoursSpecification": [{
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
      "opens": "08:00",
      "closes": "18:00"
    }],
    "sameAs": ["https://www.linkedin.com/company/cybercon-solutions"],
    "knowsAbout": ["Managed IT services", "Cybersecurity", "Cloud services", "Microsoft 365", "IT compliance", "Disaster recovery"]
  }
  </script>
</head>
<body>

  <a class="skip-link" href="#top">Skip to content</a>

  <!-- ============ Header ============ -->
  <header class="site-header" id="siteHeader">
    <div class="container">
      <a class="logo" href="#top" aria-label="Cybercon Solutions home">
        <svg class="logo-mark" viewBox="0 0 96 112" fill="none" aria-hidden="true">
          <path d="M20 12 H76 a8 8 0 0 1 8 8 V58 C84 85 65 101 48 107 C31 101 12 85 12 58 V20 a8 8 0 0 1 8 -8 Z" stroke="#F26B5E" stroke-width="6" stroke-linejoin="round"/>
          <g stroke="#F26B5E" stroke-width="2.5" stroke-linecap="round">
            <line x1="30" y1="38" x2="50" y2="28"/><line x1="50" y1="28" x2="40" y2="58"/>
            <line x1="50" y1="28" x2="66" y2="44"/><line x1="66" y1="44" x2="62" y2="66"/>
            <line x1="40" y1="58" x2="62" y2="66"/><line x1="40" y1="58" x2="34" y2="78"/>
            <line x1="62" y1="66" x2="56" y2="86"/>
          </g>
          <g fill="#F26B5E">
            <circle cx="30" cy="38" r="3.5"/><circle cx="50" cy="28" r="5"/><circle cx="66" cy="44" r="4"/>
            <circle cx="40" cy="58" r="6"/><circle cx="62" cy="66" r="4"/><circle cx="34" cy="78" r="3.5"/><circle cx="56" cy="86" r="3.5"/>
          </g>
        </svg>
        <span class="logo-word" aria-hidden="true"><span class="lw-1">CYBERCON</span> <span class="lw-2">SOLUTIONS</span></span>
      </a>
      <nav aria-label="Primary">
        <a href="#services">Services</a>
        <a href="#process">Method</a>
        <a href="#pricing">Pricing</a>
        <a href="#about">About</a>
        <a href="#insights">Insights</a>
        <a href="#contact" class="btn btn-primary nav-cta" data-scroll-to="#contact">
          <span class="label-full">Talk to an engineer</span>
          <span class="label-compact">Contact</span>
          <i data-lucide="arrow-right" class="icon" aria-hidden="true"></i>
        </a>
      </nav>
    </div>
  </header>

  <main id="top">

    <!-- ============ Hero (full-screen image, ported from HeroSection component) ============ -->
    <section class="hero hero-image" aria-labelledby="hero-heading">
      <div class="hero-bg" aria-hidden="true"></div>
      <div class="hero-scrim" aria-hidden="true"></div>
      <div class="hero-inner">
        <span class="eyebrow on-dark">CYBERCON Solutions</span>
        <h1 class="hero-title" id="hero-heading">Technology,<br />handled.</h1>
        <p class="hero-subtitle">Proactive, security-first managed IT — explained clearly, owned fully. So you can run your business with total confidence.</p>
        <div class="hero-actions">
          <a class="btn btn-primary btn-lg" href="#contact" data-scroll-to="#contact">Get a Free Assessment <i data-lucide="arrow-right" class="icon" aria-hidden="true"></i></a>
          <a class="btn btn-lg btn-glass" href="#process" data-scroll-to="#process">How it works</a>
        </div>
      </div>
    </section>

    <!-- ============ Stats ============ -->
    <section class="stats" aria-label="By the numbers">
      <div class="container grid" data-reveal-group>
        <div class="stat reveal">
          <div class="n"><span class="num" data-count="99.9" data-decimals="1">99.9</span><span class="accent">%</span></div>
          <div class="lab">Uptime, last 12 mo.</div>
        </div>
        <div class="stat reveal">
          <div class="n"><span class="num" data-count="14">14</span><span class="accent">m</span></div>
          <div class="lab">Median first response</div>
        </div>
        <div class="stat reveal">
          <div class="n"><span class="num" data-count="240">240</span><span class="accent">+</span></div>
          <div class="lab">Endpoints managed</div>
        </div>
        <div class="stat reveal">
          <div class="n"><span class="num" data-count="12">12</span><span class="accent">yr</span></div>
          <div class="lab">Average tenure with us</div>
        </div>
      </div>
    </section>

    <!-- ============ Our Method (ExoSource pattern, Cybercon palette) ============ -->
    <section class="section method" id="process" aria-labelledby="method-heading">
      <div class="container">
        <div class="section-intro" data-reveal-group>
          <span class="eyebrow reveal"><span class="tick"></span>Our method</span>
          <h2 class="h-section reveal" id="method-heading">Three steps. No fog. No surprises.</h2>
          <p class="lead reveal">Every engagement runs the same lane — assess, optimize, then manage. You always know exactly where you are.</p>
        </div>
        <ol class="method-steps" data-reveal-group>
          <li class="method-step reveal">
            <div class="ms-art">
              <img src="assets/method/assess.png" alt="" loading="lazy" width="220" height="220" />
            </div>
            <div class="ms-num">01</div>
            <h3>Assess</h3>
            <p>We take a good look at your network, then hand you a clear, plain-English service proposal built around what you actually need.</p>
          </li>
          <li class="method-step reveal">
            <div class="ms-art">
              <img src="assets/method/optimize.png" alt="" loading="lazy" width="220" height="220" />
            </div>
            <div class="ms-num">02</div>
            <h3>Optimize</h3>
            <p>We clean up and document your network top to bottom, so it can be managed and supported efficiently — no mystery boxes.</p>
          </li>
          <li class="method-step reveal">
            <div class="ms-art">
              <img src="assets/method/manage.png" alt="" loading="lazy" width="220" height="220" />
            </div>
            <div class="ms-num">03</div>
            <h3>Manage &amp; support</h3>
            <p>We install our remote-support tooling and take ownership of your infrastructure — monitoring, patching, and answering the phone.</p>
          </li>
        </ol>
      </div>
    </section>

    <!-- ============ Services ============ -->
    <section class="section alt services" id="services" aria-labelledby="services-heading">
      <div class="container">
        <div class="section-intro" data-reveal-group>
          <span class="eyebrow reveal"><span class="tick"></span>What we do</span>
          <h2 class="h-section reveal" id="services-heading">The whole IT lane — without the fluff.</h2>
          <p class="lead reveal">Six services, one team, one phone number. We don't hand you off.</p>
        </div>
        <div class="grid" data-reveal-group>
          <a class="service-card reveal" href="#contact" data-scroll-to="#contact">
            <span class="icon-tile"><i data-lucide="bot" aria-hidden="true"></i></span>
            <h3>AI Automation</h3>
            <p>We wire the busywork to itself — ticket routing, reporting, onboarding steps — on the tools you already pay for, with a human watching.</p>
            <span class="more">Learn more <i data-lucide="arrow-right" class="icon" aria-hidden="true"></i></span>
          </a>
          <a class="service-card reveal" href="#contact" data-scroll-to="#contact">
            <span class="icon-tile"><i data-lucide="headset" aria-hidden="true"></i></span>
            <h3>Managed IT &amp; Help Desk</h3>
            <p>24/7 monitoring, patching, and a real engineer when you call. Median first response under 14 minutes. We pick up, then we fix it.</p>
            <span class="more">Learn more <i data-lucide="arrow-right" class="icon" aria-hidden="true"></i></span>
          </a>
          <a class="service-card reveal" href="#contact" data-scroll-to="#contact">
            <span class="icon-tile"><i data-lucide="shield-check" aria-hidden="true"></i></span>
            <h3>Cybersecurity</h3>
            <p>Posture review, endpoint hardening, email and identity protection, and tabletop drills with your team — not just a PDF.</p>
            <span class="more">Learn more <i data-lucide="arrow-right" class="icon" aria-hidden="true"></i></span>
          </a>
          <a class="service-card reveal" href="#contact" data-scroll-to="#contact">
            <span class="icon-tile"><i data-lucide="cloud" aria-hidden="true"></i></span>
            <h3>Cloud &amp; Microsoft 365</h3>
            <p>Microsoft 365, Azure, and AWS — set up properly, locked down, and right-sized to what you actually use.</p>
            <span class="more">Learn more <i data-lucide="arrow-right" class="icon" aria-hidden="true"></i></span>
          </a>
          <a class="service-card reveal" href="#contact" data-scroll-to="#contact">
            <span class="icon-tile"><i data-lucide="database-backup" aria-hidden="true"></i></span>
            <h3>Compliance &amp; Backup/DR</h3>
            <p>HIPAA, PCI, and SOC 2 readiness, plus real backups and tested restores. A recovery plan you've rehearsed before the bad day.</p>
            <span class="more">Learn more <i data-lucide="arrow-right" class="icon" aria-hidden="true"></i></span>
          </a>
          <a class="service-card reveal" href="#contact" data-scroll-to="#contact">
            <span class="icon-tile"><i data-lucide="compass" aria-hidden="true"></i></span>
            <h3>vCIO &amp; Strategy</h3>
            <p>Quarterly roadmaps, budget planning, and a seat at your leadership table. Strategic, not vendor-pitched.</p>
            <span class="more">Learn more <i data-lucide="arrow-right" class="icon" aria-hidden="true"></i></span>
          </a>
        </div>
      </div>
    </section>

    <!-- ============ Pricing calculator (stations / users / servers) ============ -->
    <section class="section pricing" id="pricing" aria-labelledby="pricing-heading">
      <div class="container">
        <div class="section-intro" data-reveal-group>
          <span class="eyebrow reveal"><span class="tick"></span>Pricing calculator</span>
          <h2 class="h-section reveal" id="pricing-heading">Know your number before you call.</h2>
          <p class="lead reveal">A ballpark for fully managed IT across your team. Built for companies with fewer than 50 workstations — for larger networks, let's talk.</p>
        </div>

        <div class="pricing-grid" data-reveal-group>
          <div class="pricing-inputs reveal">
            <div class="stepper-field">
              <label class="stepper-label" for="in-stations">Computer stations</label>
              <div class="stepper">
                <button type="button" data-step="stations" data-dir="-1" aria-label="Decrease computer stations">&minus;</button>
                <input type="number" id="in-stations" name="stations" value="10" min="1" max="49" inputmode="numeric" aria-label="Number of computer stations" />
                <button type="button" data-step="stations" data-dir="1" aria-label="Increase computer stations">+</button>
              </div>
            </div>

            <div class="stepper-field">
              <label class="stepper-label" for="in-users">Users</label>
              <div class="stepper">
                <button type="button" data-step="users" data-dir="-1" aria-label="Decrease users">&minus;</button>
                <input type="number" id="in-users" name="users" value="10" min="1" max="49" inputmode="numeric" aria-label="Number of users" />
                <button type="button" data-step="users" data-dir="1" aria-label="Increase users">+</button>
              </div>
            </div>

            <div class="stepper-field">
              <label class="stepper-label" for="in-servers">Servers</label>
              <div class="stepper">
                <button type="button" data-step="servers" data-dir="-1" aria-label="Decrease servers">&minus;</button>
                <input type="number" id="in-servers" name="servers" value="1" min="0" max="20" inputmode="numeric" aria-label="Number of servers" />
                <button type="button" data-step="servers" data-dir="1" aria-label="Increase servers">+</button>
              </div>
            </div>

            <fieldset class="addons">
              <legend>Optional add-ons</legend>
              <label class="addon">
                <span class="addon-text"><span class="addon-name">Microsoft 365</span><span class="addon-hint">+$12 / user</span></span>
                <input type="checkbox" data-addon="m365" />
                <span class="addon-switch" aria-hidden="true"></span>
              </label>
              <label class="addon">
                <span class="addon-text"><span class="addon-name">Managed antivirus</span><span class="addon-hint">+$7 / station</span></span>
                <input type="checkbox" data-addon="av" />
                <span class="addon-switch" aria-hidden="true"></span>
              </label>
              <label class="addon">
                <span class="addon-text"><span class="addon-name">Cloud backups</span><span class="addon-hint">+$10 / station</span></span>
                <input type="checkbox" data-addon="backup" />
                <span class="addon-switch" aria-hidden="true"></span>
              </label>
              <label class="addon">
                <span class="addon-text"><span class="addon-name">Advanced security</span><span class="addon-hint">+$15 / user</span></span>
                <input type="checkbox" data-addon="security" />
                <span class="addon-switch" aria-hidden="true"></span>
              </label>
            </fieldset>
          </div>

          <aside class="pricing-result reveal" aria-live="polite">
            <span class="pr-glow" aria-hidden="true"></span>
            <div class="pr-head">
              <span class="pr-label">Estimated monthly</span>
              <span class="pr-tag">Billed monthly</span>
            </div>
            <div class="pr-amount">
              <span class="pr-cur">$</span><span id="pr-value">974</span><span class="pr-per">/mo</span>
            </div>
            <ul class="pr-breakdown" id="prBreakdown"></ul>
            <p class="pr-note">Estimate only — your exact quote comes after a free assessment. No obligation, cancel anytime.</p>
            <a href="#contact" class="btn btn-primary btn-block" data-scroll-to="#contact">
              Get a tailored quote
              <i data-lucide="arrow-right" class="icon" aria-hidden="true"></i>
            </a>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============ Inverse callout ============ -->
    <section class="section inverse callout" id="about" aria-labelledby="about-heading">
      <div class="container grid" data-reveal-group>
        <div>
          <span class="eyebrow on-dark reveal"><span class="tick"></span>The tagline</span>
          <h2 class="h-section on-dark reveal" id="about-heading">The most complex problems often have the <em>simplest</em> solutions.</h2>
          <p class="lead wide on-dark reveal">We've been doing this long enough to know that almost every fire starts with a missed update, an unowned mailbox, or a process nobody wrote down. We chase the simple stuff first.</p>
        </div>
        <a href="#process" class="btn btn-secondary inverse reveal" data-scroll-to="#process">Read our approach</a>
      </div>
    </section>

    <!-- ============ Contact ============ -->
    <section class="section contact" id="contact" aria-labelledby="contact-heading">
      <div class="container">
        <div class="section-intro" data-reveal-group>
          <span class="eyebrow reveal"><span class="tick"></span>Get in touch</span>
          <h2 class="h-section reveal" id="contact-heading">Tell us what's on fire.</h2>
          <p class="lead reveal">No sales call. One of our engineers reads it, replies within a business day, and either books a 20-minute call or sends you a quick fix.</p>
        </div>

        <div class="contact-grid">
          <div class="contact-cards" data-reveal-group>
            <!-- New business — heading copied from ExoSource "Get started today. Contact us." -->
            <div class="cta-card reveal">
              <span class="cta-eyebrow">New business</span>
              <h3>Get started today. Contact us.</h3>
              <p>Talk to an engineer and get a free network assessment — no obligation, no sales gauntlet.</p>
              <ul class="cta-lines">
                <li><span class="icon-tile sm"><i data-lucide="mail" aria-hidden="true"></i></span><a href="mailto:hello@cyberconsolutions.com">hello@cyberconsolutions.com</a></li>
                <li><span class="icon-tile sm"><i data-lucide="map-pin" aria-hidden="true"></i></span><span>Cooper City, FL &amp; South Florida</span></li>
              </ul>
            </div>
            <!-- Existing clients — heading copied from ExoSource "Already a client? Need support?" -->
            <div class="cta-card reveal">
              <span class="cta-eyebrow">Client support</span>
              <h3>Already a client? Need support?</h3>
              <p>Our help desk is open 8a&ndash;6p, Monday to Friday. 24/7 monitoring is always on.</p>
              <ul class="cta-lines">
                <li><span class="icon-tile sm"><i data-lucide="mail" aria-hidden="true"></i></span><a href="mailto:support@cyberconsolutions.com">support@cyberconsolutions.com</a></li>
                <li><span class="icon-tile sm"><i data-lucide="clock" aria-hidden="true"></i></span><span>Mon&ndash;Fri, 8a&ndash;6p · 24/7 monitoring</span></li>
              </ul>
            </div>
          </div>

          <form class="contact-form" id="contactForm" method="POST" action="https://api.web3forms.com/submit" data-reveal novalidate>
          <div class="form-fields" id="formFields">
            <!-- Web3Forms: replace the value below with your access key (web3forms.com) -->
            <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY" />
            <input type="hidden" name="subject" value="New enquiry — Cybercon Solutions website" />
            <input type="hidden" name="from_name" value="Cybercon Solutions website" />
            <div class="field">
              <label class="field-label" for="cf-name">Your name <span class="req" aria-hidden="true">*</span></label>
              <input type="text" id="cf-name" name="name" placeholder="Alex Chen" autocomplete="name" required aria-describedby="cf-name-err" />
              <span class="field-error" id="cf-name-err" role="alert"></span>
            </div>
            <div class="field">
              <label class="field-label" for="cf-email">Work email <span class="req" aria-hidden="true">*</span></label>
              <input type="email" id="cf-email" name="email" placeholder="alex@company.com" autocomplete="email" inputmode="email" required aria-describedby="cf-email-err" />
              <span class="field-error" id="cf-email-err" role="alert"></span>
            </div>
            <div class="field">
              <label class="field-label" for="cf-phone">Phone <span class="optional">(optional)</span></label>
              <input type="tel" id="cf-phone" name="phone" placeholder="(954) 555-0100" autocomplete="tel" inputmode="tel" />
            </div>
            <div class="field">
              <label class="field-label" for="cf-message">What's going on? <span class="req" aria-hidden="true">*</span></label>
              <textarea id="cf-message" name="message" placeholder="Email is bouncing, two laptops are missing patches…" required aria-describedby="cf-message-err"></textarea>
              <span class="field-error" id="cf-message-err" role="alert"></span>
            </div>

            <!-- honeypot: real people never see or fill this -->
            <div class="hp" aria-hidden="true">
              <label for="cf-company-website">Company website</label>
              <input type="text" id="cf-company-website" name="company_website" tabindex="-1" autocomplete="off" />
            </div>

            <p class="form-error" id="formError" role="alert" hidden>We couldn’t send that just now. Please try again, or email <a href="mailto:hello@cyberconsolutions.com">hello@cyberconsolutions.com</a>.</p>
            <button type="submit" class="btn btn-primary btn-block">
              Send it over
              <i data-lucide="arrow-right" class="icon" aria-hidden="true"></i>
            </button>
            <p class="footnote">No mailing lists. No drip campaigns.</p>
          </div>
          <div class="success" id="formSuccess" hidden>
            <span class="icon-tile brand lg"><i data-lucide="check" aria-hidden="true"></i></span>
            <h3>We've got it.</h3>
            <p>An engineer will reach out within one business day.</p>
          </div>
        </form>
        </div>
      </div>
    </section>

  </main>

  <!-- ============ Technology partners ============
       PLACEHOLDER wordmarks. Replace each <li>…</li> with the official
       partner logo (grayscale SVG/PNG) once the partnerships are confirmed,
       e.g. <li class="partner reveal"><img src="assets/partners/microsoft.svg" alt="Microsoft" /></li> -->
  <section class="partners" aria-label="Technology partners">
    <div class="container">
      <p class="partners-label">Technology partners we build on</p>
      <ul class="partner-row" data-reveal-group>
        <li class="partner reveal"><img class="p-logo" src="assets/partners/microsoft-color.svg" alt="Microsoft" /></li>
        <li class="partner reveal"><img class="p-logo" src="assets/partners/dell-color.svg" alt="Dell Technologies" /></li>
        <li class="partner reveal"><img class="p-logo" src="assets/partners/cisco-color.svg" alt="Cisco" /></li>
        <li class="partner reveal"><img class="p-logo is-symbol" src="assets/partners/fortinet-color.svg" alt="Fortinet" /></li>
        <li class="partner reveal"><img class="p-logo is-symbol" src="assets/partners/vmware-color.svg" alt="VMware" /></li>
        <li class="partner reveal"><img class="p-logo is-symbol" src="assets/partners/datto-color.svg" alt="Datto" /></li>
      </ul>
    </div>
